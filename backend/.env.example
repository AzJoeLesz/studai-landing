# Copy this file to `.env` (same directory) and fill in the real values.
# NEVER commit the real .env to git.

# --- Supabase --------------------------------------------------------------
# From Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# service_role key. Do NOT expose this anywhere on the frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# User tokens are verified via Supabase's JWKS endpoint (ES256/RS256).
# We derive the URL from SUPABASE_URL — no shared secret needed.

# --- OpenAI ----------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TITLE_MODEL=gpt-4o-mini

# --- Tutor behavior --------------------------------------------------------
TUTOR_MAX_HISTORY_MESSAGES=20
TUTOR_MAX_RESPONSE_TOKENS=1000

# When true, each chat turn logs L1/L2/L3 character counts (Railway / local logs). Turn off in production if noisy.
GROUNDING_DEBUG_LOG=false

# --- CORS ------------------------------------------------------------------
# Comma-separated list of origins allowed to call this API.
CORS_ORIGINS=https://studai.hu,http://localhost:3000
