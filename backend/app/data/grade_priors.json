{
  "_meta": {
    "description": "Per-(curriculum, grade_band, topic) prior mastery estimates seeded into student_progress when a new student selects their grade. Numbers are deliberate over-confidence floors based on standard curriculum sequencing — they tell us the topic should be familiar by this band, not that the individual student has mastered it. Refined per-student by extractor signals (Phase 9A), placement quiz outcomes (Phase 9E), ratings (Phase 12), and step-checks (Phase 10).",
    "schema_version": 1,
    "sources": [
      "Hungarian National Core Curriculum (NAT 2020) — Matematika tantárgy",
      "Common Core State Standards for Mathematics (CCSSM)"
    ],
    "grade_bands": {
      "K-2": "ages 5-7  (HU: 1-2. évfolyam)",
      "3-5": "ages 8-10 (HU: 3-5. évfolyam)",
      "6-8": "ages 11-13 (HU: 6-8. évfolyam)",
      "9-10": "ages 14-15 (HU: 9-10. évfolyam)",
      "11-12": "ages 16-18 (HU: 11-12. évfolyam)",
      "university": "ages 18+"
    },
    "topic_labels_are_canonical_english_lowercase": true,
    "notes_on_use": "Pick the curriculum that best matches the user's grade_level string (Hungarian school terms map to hu_nat; 'Grade N', 'Year N' map to us_ccss). For a band the student is in, write priors for ALL topics with a value > 0 — that becomes the seed. Topics with a value of 0 represent 'should be unknown', which we don't write rows for."
  },
